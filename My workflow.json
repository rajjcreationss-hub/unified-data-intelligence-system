    {
      "parameters": {
        "jsCode": "const data = $('Code in JavaScript').first().json;\nconst message = $('Webhook').first().json.body.payload.body.toLowerCase();\n\nlet reportData = [];\nlet reportName = '';\nlet headers = [];\n\nif (message.includes('finance')) {\n  reportData = data.Finance;\n  reportName = '📊 Finance Report';\n  headers = ['Transaction ID', 'Department', 'Type', 'Description', 'Amount PKR', 'Status'];\n} else if (message.includes('ticket')) {\n  reportData = data.Ticketing;\n  reportName = '🎫 Ticketing Report';\n  headers = ['Ticket ID', 'Name', 'Batch', 'Status', 'Amount PKR'];\n} else if (message.includes('propert')) {\n  reportData = data.Properties;\n  reportName = '🏢 Properties Report';\n  headers = ['Name', 'Block', 'Status', 'Issues', 'Responsible'];\n} else if (message.includes('it') || message.includes('system')) {\n  reportData = data.IT;\n  reportName = '💻 IT Systems Report';\n  headers = ['System Name', 'Type', 'Status', 'Responsible', 'Users'];\n} else {\n  reportData = data.Finance;\n  reportName = '📊 Finance Report';\n  headers = ['Transaction ID', 'Department', 'Type', 'Description', 'Amount PKR', 'Status'];\n}\n\n// Build formatted text report\nlet report = `*${reportName}*\\n`;\nreport += `_Generated: ${new Date().toLocaleDateString()}_\\n`;\nreport += `─────────────────\\n`;\n\nreportData.forEach((row, i) => {\n  report += `\\n*${i + 1}.* `;\n  headers.forEach(h => {\n    report += `${h}: ${row[h] || 'N/A'}  `;\n  });\n  report += '\\n';\n});\n\nreport += `─────────────────\\n`;\nreport += `_Total records: ${reportData.length}_`;\n\nreturn [{ json: { reportText: report } }];"
      },
